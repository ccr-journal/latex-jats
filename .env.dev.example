# Local development configuration for the LaTeX-JATS web service.
# Copy this file to .env and fill in the ORCID sandbox credentials.
#
# Assumes you run:
#   - backend via `npm run start:api` (FastAPI on :8000)
#   - frontend via `npm run start:web` (Vite on :5173)
# or both together via `npm start`.

# ── URLs (explicit; do NOT set SITE_ADDRESS locally) ──────────────────────────

# SITE_ADDRESS is a Caddy placeholder used in production. Leaving it unset
# means FRONTEND_URL and ORCID_REDIRECT_URI fall back to localhost values.
# Uncommenting SITE_ADDRESS locally will break the OAuth redirect.

FRONTEND_URL=http://localhost:5173
ORCID_REDIRECT_URI=http://127.0.0.1:8000/api/auth/orcid/callback

# ── ORCID OAuth (sandbox) ─────────────────────────────────────────────────────

# Register a sandbox app at https://sandbox.orcid.org/developer-tools.
# The redirect URI registered there must match ORCID_REDIRECT_URI above
# exactly (including scheme, host, port, and path).
ORCID_ENV=sandbox
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=change-me

# Sandbox ORCID accounts need a verified email; mailinator.com addresses work
# for throwaway accounts during testing.

# ── OJS (optional locally) ────────────────────────────────────────────────────

# Leave OJS_* unset for offline local dev. With no admin token configured,
# fetch_editor_orcids returns just the override set below, and the production
# submission picker returns an empty list (use the "Advanced: enter manually"
# fallback in the New Manuscript dialog).
#
# To point at a real OJS instance, uncomment and fill in:
# OJS_BASE_URL=https://journal.computationalcommunication.org
# OJS_JOURNAL_PATH=ccr
# OJS_ADMIN_TOKEN=...
# OJS_DOI_PREFIX=10.5117/

# Your own sandbox ORCID — makes you an editor locally without OJS.
# To test author-side access, remove your ORCID from this list and manually
# insert a ManuscriptAuthor row linking your ORCID to an existing manuscript.
OJS_EDITOR_OVERRIDE_ORCIDS=0000-0000-0000-0000

# ── Sessions ──────────────────────────────────────────────────────────────────

# SESSION_TOKEN_TTL_DAYS=30

# ── SMTP (optional — enables "Invite authors" email) ─────────────────────────

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=app-password-here
# SMTP_FROM=noreply@example.com
