# Local development configuration for the JATSmith web service.
# Copy this file to .env and adjust values as needed.
#
# Assumes you run:
#   - backend via `npm run start:api` (FastAPI on :8000)
#   - frontend via `npm run start:web` (Vite on :5173)
# or both together via `npm start`.

# ── URLs (explicit; do NOT set SITE_ADDRESS locally) ──────────────────────────

# SITE_ADDRESS is a Caddy placeholder used in production. Leaving it unset
# means FRONTEND_URL falls back to the localhost value below.

FRONTEND_URL=http://localhost:5173

# ── Editor login ──────────────────────────────────────────────────────────────

# Username:password pairs for editor logins. Two formats:
#   - plain string → single user "editor" with that password
#   - pairs: user1:pw1,user2:pw2
EDITOR_CREDENTIALS=editor:devpass

# ── OJS (optional locally) ────────────────────────────────────────────────────

# Leave OJS_ADMIN_TOKEN unset for offline local dev. With no admin token, the
# production submission picker returns an empty list (use the "Advanced: enter
# manually" fallback in the New Manuscript dialog).
#
# To point at a real OJS instance, uncomment and fill in:
# OJS_BASE_URL=https://journal.computationalcommunication.org
# OJS_JOURNAL_PATH=ccr
# OJS_ADMIN_TOKEN=...
# OJS_DOI_PREFIX=10.5117/

# ── Sessions ──────────────────────────────────────────────────────────────────

# SESSION_TOKEN_TTL_DAYS=30

# ── Upstream source tokens (Fernet key for encrypting git PATs at rest) ──────

# Generate one with: python -c "from cryptography.fernet import Fernet;
# print(Fernet.generate_key().decode())"
# If unset, dev starts with an ephemeral key and logs a warning — any stored
# upstream tokens become undecryptable after a restart, which is fine for dev.
# STORAGE_SECRET_KEY=

# ── SMTP (optional — enables "Invite authors" email) ─────────────────────────

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=app-password-here
# SMTP_FROM=noreply@example.com
