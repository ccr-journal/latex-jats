      \field{journaltitle}{Political Communication}
      \field{month}{10}
      \field{number}{4}
      \field{shorttitle}{Effects of {Economic} and {Symbolic} {Threat} {Appeals} in {Right}-{Wing} {Populist} {Advertising} on {Anti}-{Immigrant} {Attitudes}}
      \field{title}{Effects of Economic and Symbolic Threat Appeals in Right-Wing Populist Advertising on Anti-Immigrant Attitudes: The Impact of Textual and Visual Appeals}
