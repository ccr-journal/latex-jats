# Configuration for the LaTeX-JATS web service.
# Copy this file to .env and fill in the required values.

# ── Deployment ────────────────────────────────────────────────────────────────

# Public hostname Caddy serves on. Bare domain (no scheme). Use "localhost"
# (the default) to run the stack locally without TLS.
SITE_ADDRESS=jats.example.com

# Host ports mapped by docker-compose. Leave as-is unless another service
# already occupies 80/443.
HTTP_PORT=80
HTTPS_PORT=443

# ── ORCID OAuth (required) ────────────────────────────────────────────────────

# Create an app at https://orcid.org/developer-tools (production) or
# https://sandbox.orcid.org/developer-tools (testing). Redirect URI on the
# ORCID side must exactly match ORCID_REDIRECT_URI below.
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=change-me

# "production" (default) or "sandbox". Sandbox accounts can't sign in to the
# production ORCID and vice versa. Override to "sandbox" only when developing
# against a sandbox ORCID app.
# ORCID_ENV=production

# Optional — defaults to https://{SITE_ADDRESS}/api/auth/orcid/callback
# when SITE_ADDRESS is a real domain. Set explicitly if you need a different
# callback (e.g. a staging subpath).
# ORCID_REDIRECT_URI=https://jats.example.com/api/auth/orcid/callback

# Optional — defaults to https://{SITE_ADDRESS}. Used to redirect back to
# the SPA after a successful OAuth round-trip.
# FRONTEND_URL=https://jats.example.com

# ── OJS (required for editor authentication) ──────────────────────────────────

# Journal-level API settings. The admin token gates "who is a CCR editor";
# generate it on the CCR OJS admin profile (Profile → API Key). Use a
# dedicated service account rather than a personal admin token so rotation
# doesn't break when people change roles.
OJS_BASE_URL=https://journal.computationalcommunication.org
OJS_JOURNAL_PATH=ccr
OJS_ADMIN_TOKEN=change-me

# How long the backend caches the OJS editor list in memory. Keep short
# enough that newly added editors can log in reasonably soon.
# OJS_EDITOR_CACHE_TTL_SECONDS=300

# Dev-only bypass: comma-separated ORCIDs that are treated as editors even
# when they aren't in OJS. Useful for testing with sandbox ORCIDs. Do NOT
# set in production.
# OJS_EDITOR_OVERRIDE_ORCIDS=0000-0000-0000-0000

# ── Sessions ──────────────────────────────────────────────────────────────────

# How long an issued session token is valid.
# SESSION_TOKEN_TTL_DAYS=30
